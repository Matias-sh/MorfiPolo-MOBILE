<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="@dimen/spacing_m">

    <LinearLayout
        android:id="@+id/optionNameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_s">

        <ImageView
            android:id="@+id/selectedIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/spacing_s"
            android:src="@android:drawable/checkbox_on_background"
            android:contentDescription="Seleccionado"
            app:tint="@color/color_success"
            android:visibility="gone" />

        <TextView
            android:id="@+id/optionNameTextView"
            style="@style/TextAppearance.Morfipolo.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Opción 1: Hamburguesas con arroz"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/optionButton"
        style="@style/Widget.Morfipolo.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/choose_option"
        app:icon="@android:drawable/ic_menu_add"
        app:iconGravity="textStart" />

</LinearLayout>
