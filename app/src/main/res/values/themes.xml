<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.Morfipolo" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary: Slate 700 -->
        <item name="colorPrimary">@color/slate_700</item>
        <item name="colorPrimaryVariant">@color/slate_600</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary: Slate 600 -->
        <item name="colorSecondary">@color/slate_600</item>
        <item name="colorSecondaryVariant">@color/slate_700</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorError">@color/red_600</item>
        <item name="colorOnError">@color/white</item>

        <!-- Surfaces -->
        <item name="android:windowBackground">@color/neutral_50</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/neutral_900</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/neutral_900</item>
        <item name="android:textColorSecondary">@color/neutral_500</item>
        <item name="android:fontFamily">sans-serif</item>

        <!-- System Bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/food_ripple</item>
    </style>

    <style name="Theme.Morfipolo" parent="Base.Theme.Morfipolo" />

    <!-- ============================================================ -->
    <!-- BUTTONS                                                       -->
    <!-- ============================================================ -->

    <!-- Primary button — Slate 700 solid, 12dp corners -->
    <style name="Widget.Morfipolo.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/bg_button_orange_pill</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Secondary button -->
    <style name="Widget.Morfipolo.Button.Secondary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/slate_600</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Outline button -->
    <style name="Widget.Morfipolo.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/slate_700</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/slate_700</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <!-- ============================================================ -->
    <!-- CARDS                                                         -->
    <!-- ============================================================ -->

    <!-- Main card style — white, 16dp corners, subtle elevation -->
    <style name="Widget.Morfipolo.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Card with more lift -->
    <style name="Widget.Morfipolo.Card.Lifted" parent="Widget.Morfipolo.Card">
        <item name="cardElevation">4dp</item>
    </style>

    <!-- ============================================================ -->
    <!-- TYPOGRAPHY                                                    -->
    <!-- ============================================================ -->

    <style name="TextAppearance.Morfipolo.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/neutral_900</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Morfipolo.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/neutral_900</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Morfipolo.Subhead" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/neutral_500</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Morfipolo.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/neutral_500</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ============================================================ -->
    <!-- TEXT INPUTS                                                   -->
    <!-- ============================================================ -->

    <style name="Widget.Morfipolo.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <item name="boxStrokeColor">@color/slate_700</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/neutral_500</item>
        <item name="boxBackgroundColor">@color/neutral_50</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- ============================================================ -->
    <!-- BOTTOM NAVIGATION INDICATOR                                  -->
    <!-- ============================================================ -->

    <style name="Widget.Morfipolo.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">52dp</item>
        <item name="android:height">52dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Morfipolo.NavIndicator</item>
    </style>

    <style name="ShapeAppearance.Morfipolo.NavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <!-- TimePicker spinner with white text for use on dark (Slate 600) card -->
    <style name="TimePickerSpinnerDark" parent="Theme.Material3.Light">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="colorAccent">@color/emerald_600</item>
    </style>

</resources>
