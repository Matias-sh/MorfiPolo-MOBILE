<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/food_background_light"
    tools:context=".ui.profile.ProfileFragment">

    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/background_rect_curved_bottom"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="80dp"
            android:paddingBottom="40dp">

            <!-- Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Morfipolo.Card"
                app:contentPadding="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/avatarCardView"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardBackgroundColor="@color/food_secondary_green_light"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp">
                        
                        <TextView
                            android:id="@+id/avatarTextView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="M"
                            android:textColor="@color/food_secondary_green_dark"
                            android:textSize="40sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/nameTextView"
                        style="@style/TextAppearance.Morfipolo.Headline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Matías Federico"
                        android:textSize="22sp"
                        android:gravity="center" />
                        
                    <TextView
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="4dp"
                         android:text="Usuario"
                         android:textSize="14sp"
                         android:textColor="@color/food_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginStart="8dp"
                android:text="Configuración"
                style="@style/TextAppearance.Morfipolo.Subhead"
                android:textSize="18sp" />

            <!-- Options -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Morfipolo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/changePasswordButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="@string/change_password"
                        android:textColor="@color/food_text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="24dp"
                        app:icon="@android:drawable/ic_menu_manage"
                        app:iconTint="@color/food_primary_orange"
                        app:iconPadding="16dp" />
                        
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/food_divider"
                        android:layout_marginHorizontal="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/logoutButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="@string/logout"
                        android:textColor="@color/food_status_error"
                        android:gravity="start|center_vertical"
                        android:paddingStart="24dp"
                        app:icon="@android:drawable/ic_menu_close_clear_cancel"
                        app:iconTint="@color/food_status_error"
                        app:iconPadding="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <LinearLayout
                android:id="@+id/developmentFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical"
                android:gravity="center"
                android:alpha="0.7">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/di_logo"
                    android:contentDescription="Logo Dirección de Ingeniería" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Desarrollado por la\nDirección de Ingeniería"
                    android:gravity="center"
                    android:textColor="@color/food_text_secondary"
                    android:textSize="12sp" />

                 <ImageView
                    android:layout_width="150dp"
                    android:layout_height="50dp"
                    android:src="@drawable/sello_gobierno_02"
                    android:layout_marginTop="12dp"
                    android:scaleType="fitCenter"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
