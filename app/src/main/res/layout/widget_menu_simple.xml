<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient_main"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- Header elegante con fondo marrón -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/nonna_brown_primary"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/widgetDateTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Menú del Día"
            android:textColor="@color/nonna_text_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetMenuDescriptionTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cargando..."
            android:textColor="@color/nonna_text_white"
            android:textSize="13sp"
            android:alpha="0.9" />

        <!-- Badge de estado -->
        <TextView
            android:id="@+id/widgetStatusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/badge_success_modern"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Abierto"
            android:textColor="@color/nonna_text_white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Lista dinámica de opciones -->
    <ListView
        android:id="@+id/widgetOptionsList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- Mensaje cuando no hay menú -->
    <TextView
        android:id="@+id/widgetNoMenuTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text=""
        android:textColor="@color/nonna_text_secondary"
        android:textSize="14sp"
        android:alpha="0.8"
        android:visibility="gone" />

</LinearLayout>