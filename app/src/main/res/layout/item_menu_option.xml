<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Morfipolo.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/food_divider">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/optionNameTextView"
            style="@style/TextAppearance.Morfipolo.Subhead"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Opción 1: Hamburguesas con arroz"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/food_text_primary"
            android:lineSpacingExtra="2dp"
            android:maxLines="4"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/statusMessageTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Usted no selecciono una opcion el dia de hoy"
            android:textSize="13sp"
            android:textColor="@color/food_text_secondary"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginTop="14dp"
            android:minWidth="0dp"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/choose_option"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:textColor="@color/white"
            app:cornerRadius="14dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
