<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:context=".ui.profile.ProfileFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fadeScrollbars="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_l">

            <!-- Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileCardView"
                style="@style/Widget.Morfipolo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_xl">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/avatarCardView"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardBackgroundColor="@color/brand_primary"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="@dimen/elevation_medium"
                        app:strokeWidth="0dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/avatarTextView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="U"
                            android:textColor="@color/white"
                            android:textSize="40sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/nameTextView"
                        style="@style/TextAppearance.Morfipolo.Headline2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_l"
                        android:text="Usuario"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/avatarCardView" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Options Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/optionsCardView"
                style="@style/Widget.Morfipolo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/profileCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_s">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/changePasswordButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="@string/change_password"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textAlignment="textStart"
                        android:gravity="center_vertical|start"
                        android:paddingStart="@dimen/spacing_m"
                        android:paddingEnd="@dimen/spacing_m"
                        app:icon="@android:drawable/ic_menu_manage"
                        app:iconGravity="textStart"
                        app:iconTint="@color/brand_primary"
                        app:iconSize="24dp"
                        app:iconPadding="@dimen/spacing_m" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/spacing_m"
                        android:background="@color/divider" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/logoutButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="@string/logout"
                        android:textColor="@color/color_error"
                        android:textSize="@dimen/text_size_body"
                        android:textAlignment="textStart"
                        android:gravity="center_vertical|start"
                        android:paddingStart="@dimen/spacing_m"
                        android:paddingEnd="@dimen/spacing_m"
                        app:icon="@android:drawable/ic_menu_close_clear_cancel"
                        app:iconGravity="textStart"
                        app:iconTint="@color/color_error"
                        app:iconSize="24dp"
                        app:iconPadding="@dimen/spacing_m"
                        app:rippleColor="@color/color_error" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <LinearLayout
                android:id="@+id/developmentFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/optionsCardView"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    style="@style/TextAppearance.Morfipolo.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Desarrollado por la Dirección de Ingeniería"
                    android:layout_marginEnd="@dimen/spacing_s"
                    android:gravity="center_vertical" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/di_logo"
                    android:contentDescription="Logo Dirección de Ingeniería" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
