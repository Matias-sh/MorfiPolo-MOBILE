<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:context=".ui.menu.daily.DailyMenuFragment">

    <!-- Offline Indicator -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/offlineIndicator"
        style="@style/Widget.Morfipolo.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_m"
        android:visibility="gone"
        app:cardBackgroundColor="@color/color_error"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_m">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white"
                android:contentDescription="@string/offline_icon" />

            <TextView
                style="@style/TextAppearance.Morfipolo.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_s"
                android:text="@string/offline_message"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Info Banner -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/infoBanner"
        style="@style/Widget.Morfipolo.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_m"
        android:layout_marginTop="@dimen/spacing_s"
        android:visibility="gone"
        app:cardBackgroundColor="@color/brand_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/offlineIndicator">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_m">

            <ImageView
                android:id="@+id/infoBannerIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/text_on_secondary"
                android:contentDescription="@string/info_icon" />

            <TextView
                android:id="@+id/infoBannerText"
                style="@style/TextAppearance.Morfipolo.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_s"
                android:text=""
                android:textColor="@color/text_on_secondary"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/infoBanner">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:fadeScrollbars="false">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_l">

                <!-- Header Date -->
                <TextView
                    android:id="@+id/dateTextView"
                    style="@style/TextAppearance.Morfipolo.Headline1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06/11/2025"
                    android:layout_marginTop="@dimen/spacing_l"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/timeRangeTextView"
                    style="@style/TextAppearance.Morfipolo.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/selection_time"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dateTextView" />

                <!-- Status Badges -->
                <LinearLayout
                    android:id="@+id/statusLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/timeRangeTextView">

                    <TextView
                        android:id="@+id/alreadySelectedTextView"
                        style="@style/TextAppearance.Morfipolo.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/badge_success_modern"
                        android:paddingHorizontal="@dimen/spacing_m"
                        android:paddingVertical="@dimen/spacing_xs"
                        android:text="@string/already_selected"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/statusTextView"
                        style="@style/TextAppearance.Morfipolo.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_s"
                        android:background="@drawable/badge_success_modern"
                        android:paddingHorizontal="@dimen/spacing_m"
                        android:paddingVertical="@dimen/spacing_xs"
                        android:text="@string/open"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Menu Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuCardContainer"
                    style="@style/Widget.Morfipolo.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_l"
                    app:layout_constraintTop_toBottomOf="@id/statusLayout">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_l">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MENU DEL DÍA"
                            style="@style/TextAppearance.Morfipolo.Caption"
                            android:textColor="@color/brand_primary"
                            android:letterSpacing="0.1"
                            android:layout_gravity="center_horizontal"/>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="2dp"
                            android:background="@color/brand_secondary"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:layout_marginBottom="@dimen/spacing_m"/>

                        <TextView
                            android:id="@+id/menuDescriptionTextView"
                            style="@style/TextAppearance.Morfipolo.Headline2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Arrollado de pollo con pure de papas"
                            android:gravity="center"
                            android:layout_marginBottom="@dimen/spacing_l"/>

                        <View
                            android:id="@+id/divider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="@dimen/spacing_l" />

                        <LinearLayout
                            android:id="@+id/optionsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hidden legacy card to prevent crash if referenced -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuCardView"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/brand_primary"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
