<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/widgetDateTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menú del Día"
        android:textColor="#263238"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetMenuDescriptionTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Cargando..."
        android:textColor="#78909C"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widgetStatusTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#66BB6A"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="Abierto"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />


    <LinearLayout
        android:id="@+id/widgetOption1Container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widgetOption1Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#263238"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widgetOption1Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="36dp"
            android:padding="8dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#42A5F5" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetOption2Container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widgetOption2Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#263238"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widgetOption2Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="36dp"
            android:padding="8dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#42A5F5" />

    </LinearLayout>

    <TextView
        android:id="@+id/widgetNoMenuTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text=""
        android:textColor="#78909C"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
