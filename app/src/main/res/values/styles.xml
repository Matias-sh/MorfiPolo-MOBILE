<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ======================================================================================= -->
    <!-- SHAPES -->
    <!-- ======================================================================================= -->
    <!-- ======================================================================================= -->
    <!-- SHAPES -->
    <!-- ======================================================================================= -->
    <style name="ShapeAppearance.Morfipolo.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_s</item>
    </style>

    <style name="ShapeAppearance.Morfipolo.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_m</item>
    </style>

    <style name="ShapeAppearance.Morfipolo.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_l</item>
    </style>

    <!-- ======================================================================================= -->
    <!-- TYPOGRAPHY -->
    <!-- ======================================================================================= -->
    <style name="TextAppearance.Morfipolo.Headline1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">@dimen/text_size_h1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Morfipolo.Headline2" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">@dimen/text_size_h2</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Morfipolo.Headline3" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">@dimen/text_size_h3</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Morfipolo.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.Morfipolo.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <!-- ======================================================================================= -->
    <!-- COMPONENT STYLES -->
    <!-- ======================================================================================= -->
    
    <!-- Buttons -->
    <!-- Buttons -->
    <style name="Widget.Morfipolo.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Morfipolo.MediumComponent</item>
        <item name="android:minHeight">56dp</item>
    </style>
    
    <style name="Widget.Morfipolo.Button.Secondary" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="backgroundTint">@color/brand_secondary</item>
        <item name="android:textColor">@color/text_on_secondary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Morfipolo.MediumComponent</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Cards -->
    <style name="Widget.Morfipolo.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardElevation">@dimen/elevation_low</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Morfipolo.MediumComponent</item>
    </style>
    
    <!-- Input Fields -->
    <style name="Widget.Morfipolo.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Morfipolo.SmallComponent</item>
        <item name="boxBackgroundColor">@color/surface_card</item>
    </style>

    <!-- Window Animations -->
    <style name="WindowAnimation.Morfipolo" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

</resources>
