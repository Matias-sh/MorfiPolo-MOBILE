<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/nonna_white_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/optionNameLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/selectedIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_check_circle"
                android:contentDescription="Seleccionado"
                android:visibility="gone" />

            <TextView
                android:id="@+id/optionNameTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Opción 1: Hamburguesas con arroz"
                android:textColor="@color/nonna_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/choose_option"
            android:textColor="@color/nonna_text_white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/button_primary_solid"
            android:maxLines="1"
            android:ellipsize="end"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_add"
            app:iconGravity="textStart"
            app:iconTint="@color/nonna_text_white"
            app:iconPadding="6dp"
            app:iconSize="18dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
