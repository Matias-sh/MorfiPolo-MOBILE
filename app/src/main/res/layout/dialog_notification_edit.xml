<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/edit_alert_title"
        android:textColor="@color/neutral_900"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/edit_alert_subtitle"
        android:textColor="@color/neutral_500"
        android:textSize="13sp" />

    <!-- Time picker container — Slate 600 background card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/slate_600"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <TimePicker
            android:id="@+id/timePicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:timePickerMode="spinner"
            android:theme="@style/TimePickerSpinnerDark" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Repeat label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/repeat_each_week"
        android:textColor="@color/slate_700"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Day chips row -->
    <HorizontalScrollView
        android:id="@+id/daysScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/daysContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="4dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/mondayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/tuesdayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/wednesdayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/thursdayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="J"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/fridayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/saturdayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/sundayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D"
                android:checkable="true"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:chipStrokeWidth="0dp"
                app:chipMinHeight="44dp"
                android:minWidth="52dp"
                android:textColor="@color/chip_text_selector"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Delete button (text link, red) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/delete"
        android:textColor="@color/red_600"
        style="@style/Widget.Material3.Button.TextButton" />

    <!-- Note: Save / Cancel buttons are added by AlertDialog.Builder — do NOT add them here -->

</LinearLayout>
